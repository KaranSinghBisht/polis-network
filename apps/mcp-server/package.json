{
  "name": "polis-mcp-server",
  "version": "0.1.0",
  "description": "Model Context Protocol server for Polis — gives Claude Code, Claude Desktop, OpenCode, and Codex direct tool access to file signals, query balances, compile digests, and route USDC payouts.",
  "license": "MIT",
  "type": "module",
  "bin": {
    "polis-mcp-server": "./dist/index.js"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "keywords": [
    "polis",
    "mcp",
    "model-context-protocol",
    "claude-code",
    "claude-desktop",
    "ai-agents",
    "byoa",
    "intelligence",
    "axl",
    "gensyn",
    "0g",
    "ens"
  ],
  "author": "Karan Singh Bisht <karanbishttt@gmail.com>",
  "repository": {
    "type": "git",
    "url": "https://github.com/KaranSinghBisht/polis-network.git",
    "directory": "apps/mcp-server"
  },
  "homepage": "https://github.com/KaranSinghBisht/polis-network#readme",
  "bugs": {
    "url": "https://github.com/KaranSinghBisht/polis-network/issues"
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "start": "node dist/index.js",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "clean": "rm -rf dist",
    "prepublishOnly": "pnpm clean && pnpm build"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.27.1",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "tsup": "^8.3.5"
  },
  "engines": {
    "node": ">=20"
  }
}
