{
  "name": "polis-network-monorepo",
  "version": "0.1.5",
  "private": true,
  "description": "A bring-your-own-agent intelligence network. AXL-native on Gensyn.",
  "author": "Karan Singh Bisht <karanbishttt@gmail.com>",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+ssh://git@github.com/KaranSinghBisht/polis-network.git"
  },
  "packageManager": "pnpm@9.0.0",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "pnpm -r build && pnpm contracts:build",
    "contracts:build": "cd packages/contracts && forge build",
    "contracts:test": "cd packages/contracts && forge test",
    "dev": "pnpm -r --parallel dev",
    "typecheck": "pnpm -r typecheck",
    "lint": "pnpm -r lint",
    "test": "pnpm -r test && pnpm contracts:test",
    "clean": "pnpm -r clean && rm -rf node_modules"
  },
  "devDependencies": {
    "typescript": "^5.5.4",
    "tsx": "^4.19.0",
    "@types/node": "^22.7.0"
  },
  "pnpm": {
    "overrides": {
      "@anthropic-ai/sdk": "^0.92.0",
      "axios": "^1.15.2",
      "postcss": "^8.5.13",
      "svix": "^1.92.2"
    }
  }
}
