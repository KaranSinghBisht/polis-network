{
  "name": "@polis/axl-client",
  "version": "0.0.1",
  "private": true,
  "description": "TypeScript client for the AXL P2P node HTTP API (/send, /recv, /topology, /mcp, /a2a).",
  "license": "MIT",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": ["dist", "src"],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "dev": "tsc -p tsconfig.json --watch",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "undici": "^6.20.0"
  }
}
