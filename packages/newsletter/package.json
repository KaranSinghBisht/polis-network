{
  "name": "@polis/newsletter",
  "version": "0.0.1",
  "private": true,
  "description": "Polis reviewer-agent digest compiler and newsletter delivery.",
  "license": "MIT",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./src/index.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./dist/index.js"
    }
  },
  "files": ["dist", "src"],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "dev": "tsc -p tsconfig.json --watch",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "node --import tsx --test test/*.test.ts",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@polis/runtime": "workspace:*",
    "resend": "^6.2.2"
  }
}
