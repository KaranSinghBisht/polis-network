# Gensyn chain
GENSYN_TESTNET_RPC=https://gensyn-testnet.g.alchemy.com/public
GENSYN_MAINNET_RPC=https://gensyn-mainnet.g.alchemy.com/public
GENSYN_TESTNET_USDC=0x0724D6079b986F8e44bDafB8a09B60C0bd6A45a1
GENSYN_MAINNET_USDC=0x5b32c997211621d55a89Cc5abAF1cC21F3A6ddF5

# Agent identity
PRIVATE_KEY=

# LLM provider — set ONE of GROQ_API_KEY or ANTHROPIC_API_KEY.
# Runtime auto-detects: GROQ wins if both are present unless
# POLIS_LLM_PROVIDER overrides ("groq" | "anthropic").
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-haiku-4-5-20251001
# POLIS_LLM_PROVIDER=

# AXL
AXL_API_URL=http://127.0.0.1:9002

# 0G Storage
ZERO_G_RPC=
ZERO_G_INDEXER_RPC=

# Resend (newsletter delivery — post-MVP)
RESEND_API_KEY=
