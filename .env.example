# Optional shell exports for scripts. The CLI does not auto-load .env; pass these
# in the shell or rely on ~/.polis/config.json created by `polis init`.
# Gensyn chain / contract deployment
GENSYN_TESTNET_RPC=https://gensyn-testnet.g.alchemy.com/public
GENSYN_MAINNET_RPC=https://gensyn-mainnet.g.alchemy.com/public
GENSYN_TESTNET_USDC=0x0724D6079b986F8e44bDafB8a09B60C0bd6A45a1
GENSYN_MAINNET_USDC=0x5b32c997211621d55a89Cc5abAF1cC21F3A6ddF5

# Contract deployment key. Runtime commands use ~/.polis/config.json unless a
# command documents an explicit env override.
PRIVATE_KEY=

# ENS identity verification. Used by `polis ens`, `polis register --ens`, and the web resolver.
POLIS_ENS_RPC_URL=https://ethereum-sepolia-rpc.publicnode.com
ENS_RPC_URL=https://ethereum.publicnode.com

# LLM provider — set ONE of GROQ_API_KEY or ANTHROPIC_API_KEY.
# Runtime auto-detects: GROQ wins if both are present unless
# POLIS_LLM_PROVIDER overrides ("groq" | "anthropic").
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-haiku-4-5-20251001
# POLIS_LLM_PROVIDER=

# AXL
AXL_API_URL=http://127.0.0.1:9002
# Required when `polis run` spawns the Gensyn AXL node binary.
AXL_NODE_BIN=

# 0G Galileo Testnet Storage (chainId 16602)
ZERO_G_RPC=https://evmrpc-testnet.0g.ai
ZERO_G_INDEXER_RPC=https://indexer-storage-testnet-turbo.0g.ai
# Optional. Defaults to the funded ~/.polis config privateKey when unset.
ZERO_G_PRIVATE_KEY=

# Resend (newsletter delivery)
RESEND_API_KEY=
POLIS_NEWSLETTER_FROM=Polis <onboarding@resend.dev>
POLIS_NEWSLETTER_TO=

# Web demo. Local file-backed proof APIs only answer localhost by default.
# Set this only if you intentionally expose the local demo over a tunnel.
POLIS_WEB_EXPOSE_LOCAL_FILES=
POLIS_WEB_LOCAL_READ_TOKEN=
POLIS_WEB_PUBLIC_DEMO=
# At least 32 characters; used to sign the web session cookie.
POLIS_AUTH_SECRET=
# Vercel KV commonly sets KV_REST_API_*. Upstash Redis sets UPSTASH_REDIS_*.
# Polis accepts either pair for web login + agent claims.
KV_REST_API_URL=
KV_REST_API_TOKEN=
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# MCP safety gates. Leave unset unless you intentionally allow side effects.
POLIS_MCP_ALLOW_WRITE=
POLIS_MCP_ALLOW_DIGEST=
POLIS_MCP_ALLOW_PAYOUT=
POLIS_MCP_ALLOW_ARBITRARY_PATHS=
